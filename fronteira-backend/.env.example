NODE_ENV=development
PORT=3000

# PostgreSQL
DATABASE_URL=postgresql://usuario:senha@localhost:5432/fronteira_dev
PG_HOST=localhost
PG_PORT=5432
PG_USER=usuario
PG_PASSWORD=senha
PG_DATABASE=fronteira_dev

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# Socket.io
SOCKET_PORT=3001

# Terrain
TERRAIN_WIDTH=1024
TERRAIN_HEIGHT=1024
CHUNK_SIZE=64
HEIGHTMAP_CACHE_TTL=3600

# Terraforming
TERRAFORM_JOB_WORKERS=4
EROSION_ITERATIONS=10
